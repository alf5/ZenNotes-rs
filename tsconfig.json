{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true,
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["./packages/app-core/src/*"],
      "@shared/*": ["./packages/shared-domain/src/*"],
      "@bridge-contract/*": ["./packages/bridge-contract/src/*"],
      "@zennotes/app-core/*": ["./packages/app-core/src/*"],
      "@zennotes/bridge-contract/*": ["./packages/bridge-contract/src/*"],
      "@zennotes/shared-domain/*": ["./packages/shared-domain/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
