# Maintainer: alf5 <alf5@users.noreply.github.com>
pkgname=zennotes-rs
pkgver=2.15.0
pkgrel=1
pkgdesc="A calm, file-based markdown notes app (Tauri desktop client)"
arch=('x86_64' 'aarch64')
url="https://github.com/alf5/ZenNotes-rs"
license=('MIT')
# Runtime: the Tauri webview + GTK stack, from Arch's own packages.
depends=('webkit2gtk-4.1' 'gtk3' 'hicolor-icon-theme')
# Build: Rust toolchain (rust provides cargo), bun to install/run the Vite
# frontend from the repo's committed bun.lock, nodejs as a fallback for tooling
# that shells out to `node`, pkgconf to locate webkit2gtk-4.1/gtk3, git for the
# source clone.
makedepends=('rust' 'bun' 'nodejs' 'pkgconf' 'git')
source=("$pkgname::git+https://github.com/alf5/ZenNotes-rs.git#tag=v$pkgver"
  "zennotes-rs.desktop")
sha256sums=('SKIP'
  '29d0643953714a755f9da9aea4236b4630d22a66956ba8bddbc428ebddb2a82d')

# Disable makepkg's global LTO for this package. ring (ureq's rustls TLS
# backend, used by the link-preview fetcher) compiles its crypto primitives
# from C/assembly; Arch's makepkg.conf enables LTO by default and injects
# -flto into those C objects, after which the asm-derived ring_core_* symbols
# don't survive to the final link (undefined reference). CI and the test suite
# link ring cleanly because neither goes through makepkg. See build() for the
# matching Rust-side LTO opt-out.
options=('!lto')

build() {
  cd "$srcdir/$pkgname"

  # Keep bun + cargo caches inside the build dir.
  export BUN_INSTALL_CACHE_DIR="$srcdir/bun-cache"
  export CARGO_HOME="${CARGO_HOME:-$srcdir/cargo-home}"

  # Also disable Rust's own release LTO (the profile sets lto = true). Paired
  # with options=('!lto') above, this makes the whole build LTO-free — matching
  # the config under which the test suite links ring — so no ring_core_*
  # symbols are lost. Env-scoped, so the tag's source is untouched; the only
  # cost is a slightly larger binary, which is secondary for a from-source pkg.
  export CARGO_PROFILE_RELEASE_LTO=false

  # Install the JS deps (vendored frontend workspace + Tauri CLI) from the
  # committed bun.lock. bun (not npm) because bun.lock is the repo's real
  # lockfile; --frozen-lockfile pins the exact, integrity-checked dependency
  # tree and fails rather than resolving fresh, so the build is reproducible.
  bun install --frozen-lockfile

  # Build the frontend (Vite, embedded into the binary) and the Rust app,
  # without producing a bundle/installer — we install files ourselves below.
  # No `--` before --no-bundle: it's a `tauri build` flag, and a `--` separator
  # would route it to the cargo runner instead (cargo: unexpected argument).
  bun run tauri build --no-bundle
}

package() {
  cd "$srcdir/$pkgname"

  # The executable (frontend is embedded; the system WebKitGTK provides the engine).
  install -Dm755 "src-tauri/target/release/zennotes-rs" "$pkgdir/usr/bin/zennotes-rs"

  # Desktop entry + icons.
  install -Dm644 "$srcdir/zennotes-rs.desktop" "$pkgdir/usr/share/applications/zennotes-rs.desktop"
  install -Dm644 "src-tauri/icons/32x32.png" "$pkgdir/usr/share/icons/hicolor/32x32/apps/zennotes-rs.png"
  install -Dm644 "src-tauri/icons/128x128.png" "$pkgdir/usr/share/icons/hicolor/128x128/apps/zennotes-rs.png"
  install -Dm644 "src-tauri/icons/128x128@2x.png" "$pkgdir/usr/share/icons/hicolor/256x256/apps/zennotes-rs.png"

  install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
